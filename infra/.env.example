# vLLM inference service
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=ibm-granite/granite-3.1-8b-instruct
VLLM_API_KEY=unused

# OpenTelemetry — OTLP export target
#
# In Kubernetes the default is the BindPlane node agent (no auth required):
#   HTTP  bindplane-node-agent.bindplane-agent.svc.cluster.local:4318
#   gRPC  bindplane-node-agent.bindplane-agent.svc.cluster.local:4317
#
# Override OTEL_EXPORTER_OTLP_ENDPOINT to target a different collector or
# send directly to Dynatrace:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://your-environment.live.dynatrace.com/api/v2/otlp
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Api-Token dt0c01.XXXXXXXX
#
# For local docker-compose dev, set OTEL_EXPORTER=console to print spans to
# stdout, or point at the bundled local collector (docker compose --profile debug):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER=console

# Service names (set per app, overridden in docker-compose.yml)
# OTEL_SERVICE_NAME=recipe-generator

# PostgreSQL (App 3 only)
DATABASE_URL=postgresql://workshop:workshop@db:5432/workshop
POSTGRES_USER=workshop
POSTGRES_PASSWORD=workshop
POSTGRES_DB=workshop
